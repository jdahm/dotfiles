#!/usr/bin/env bash

mailbase=/home/jdahm/Mail
declare -a maildir
declare -a nmail
nnew=0

# Check Mail
mbsync -q -a

# Notify
while read -r -a line; do
    [ -z "$line" ] && break;
    maildir+=${line[-1]#*${mailbase}}
    nmail+=("${line[2]}")
    nnew=$(($nnew+${nmail[$i]}))
done <<<$(mailcheck | grep new)

if [ $nnew > 0 ]; then
    s=""
    for ((i=0;i<${#maildir[@]};++i)); do
        s+="${nmail[$i]} new message(s) in ${maildir[$i]}"
    done
    notify-send -c email.arrived -u normal -i mail_new "$s"
fi

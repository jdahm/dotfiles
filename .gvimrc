" Set font
set guifont=DejaVuSansMono:h14
" Colorscheme, in terminal vim this isn't necessary
silent! colorscheme base16-eighties

" Use mouse in GUI
set mouse=a

" Use command-line dialogs instead of pop-up windows
" http://stackoverflow.com/questions/4193654/using-vim-warning-style-in-gvim
set guioptions+=c
" Disable toolbar
set guioptions-=T

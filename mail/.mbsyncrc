IMAPAccount fastmail-account
        # Address to connect to
        Host mail.messagingengine.com
        User jdahm@fastmail.com
        PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.mailpass-fm.gpg"
        # `UseIMAPS' is required since FM disabled insecure connections
        UseIMAPS yes
        RequireSSL yes
        CertificateFile /etc/ssl/certs/ca-certificates.crt
        # for newer version
        # SSLType IMAPS
        # SSLVersions TLSv1

IMAPAccount umich-account
        # Address to connect to
        Host imap.gmail.com
        User jdahm@umich.edu
        PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.mailpass-umich.gpg"
        # `UseIMAPS' is required since FM disabled insecure connections
        UseIMAPS yes
        RequireSSL yes
        CertificateFile /etc/ssl/certs/ca-certificates.crt
        # for newer version
        # SSLType IMAPS
        # SSLVersions TLSv1

IMAPStore fastmail-imap
	Account	fastmail-account

IMAPStore umich-imap
        Account umich-account

MaildirStore fastmail-local
        # The trailing "/" is important
	Path	~/Mail/fm/
	Inbox	~/Mail/fm/Inbox

MaildirStore umich-local
        Path ~/Mail/um/
        Inbox ~/Mail/um/Inbox

Channel fm-inbox
        Master :fastmail-imap:INBOX
        Slave  :fastmail-local:Inbox
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel fm-folders
        Master :fastmail-imap:INBOX/
        Slave  :fastmail-local:
        Patterns * !INBOX !Drafts !Trash !Spam
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel umich-inbox
        Master ":umich-imap:INBOX"
        Slave ":umich-local:Inbox"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel umich-sent
        Master ":umich-imap:[Gmail]/Sent Mail"
        Slave ":umich-local:Sent Mail"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel umich-archived
        Master ":umich-imap:Archived"
        Slave ":umich-local:Archive"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel umich-spam
        Master ":umich-imap:[Gmail]/Spam"
        Slave ":umich-local:Spam"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Group all
        Channels fm-inbox fm-folders umich-inbox umich-sent umich-archived umich-spam
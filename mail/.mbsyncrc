IMAPAccount fm-account
        # Address to connect to
        Host mail.messagingengine.com
        User jdahm@fastmail.com
        PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.mailpass-fm.gpg"
        SSLType IMAPS
        SSLVersions TLSv1

IMAPAccount um-account
        # Address to connect to
        Host imap.gmail.com
        User jdahm@umich.edu
        PassCmd "gpg2 -q --for-your-eyes-only --no-tty -d ~/.mailpass-umich.gpg"
        SSLType IMAPS
        SSLVersions TLSv1

IMAPStore fm-imap
	Account	fm-account

IMAPStore um-imap
        Account um-account

MaildirStore fm-local
        # The trailing "/" is important
	Path	~/Mail/fm/
	Inbox	~/Mail/fm/Inbox

MaildirStore um-local
        Path ~/Mail/um/
        Inbox ~/Mail/um/Inbox

Channel fm-inbox
        Master :fm-imap:INBOX
        Slave  :fm-local:Inbox
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel fm-folders
        Master :fm-imap:
        Slave  :fm-local:
        # Patterns * !INBOX
        Patterns * !INBOX
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-inbox
        Master ":um-imap:INBOX"
        Slave ":um-local:Inbox"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-sent
        Master ":um-imap:[Gmail]/Sent Mail"
        Slave ":um-local:Sent Mail"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-archived
        Master ":um-imap:Archived"
        Slave ":um-local:Archive"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-spam
        Master ":um-imap:[Gmail]/Spam"
        Slave ":um-local:Spam"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-trash
        Master ":um-imap:[Gmail]/Trash"
        Slave ":um-local:Trash"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Channel um-drafts
        Master ":um-imap:[Gmail]/Drafts"
        Slave ":um-local:Drafts"
        Create Slave
        SyncState *
        Sync All
        Expunge Both

Group all
        Channels fm-inbox fm-folders um-inbox um-sent um-archived um-spam um-trash um-drafts

Group inbox
      Channels fm-inbox um-inbox
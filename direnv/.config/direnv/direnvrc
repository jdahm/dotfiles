use_python() {
    if [ -n "$(which pyenv)" ]; then
        local pyversion=$1
        pyenv local ${pyversion}
    fi
}

layout_virtualenv() {
    local pyversion=$1
    local pvenv=$2
    local name=${pvenv}-${pyversion}
    if [ ! -d "$(pyenv root)/versions/${name}" ]; then
        pyenv virtualenv --force --quiet ${pyversion} ${name}
    fi
    pyenv local --unset
}

layout_activate() {
    if [ -n "$(which pyenv)" ]; then
        source $(pyenv root)/versions/$1/bin/activate
    fi
}
